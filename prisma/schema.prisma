// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Роли (ARCHITECTURE §4). Источник правды по правам — только сессия, см. §6.
enum Role {
  ADMIN
  DISPATCHER
  DRIVER
}

// Статусы задачи (ARCHITECTURE §5). Переходы — только через матрицу в src/domain/task-status.ts.
enum TaskStatus {
  NEW
  ASSIGNED
  ACCEPTED
  EN_ROUTE
  ON_SITE
  DONE
  ON_HOLD
  RESCHEDULED
  CANCELLED
}

// Статус пропуска на объект (PRD §6).
enum PassStatus {
  NOT_NEEDED
  NEEDED
  ORDERED
}

// Оплата (PRD §4): нет / через офис / на месте.
enum PaymentType {
  NONE
  OFFICE
  ON_SITE
}

// Вид вложения (ARCHITECTURE §4). Фото — отчётные и приложенные при постановке.
enum AttachmentKind {
  PHOTO
  DOCUMENT
}

// Состояние ведомости работ (этап 12, PRD §13.4). На задаче null — ведомость не нужна
// (тип без requiresPricing). Жизненный цикл живёт отдельно от статуса задачи.
enum WorksheetStatus {
  DRAFT // водитель заполняет
  PRICING // отправлена диспетчеру на расценку (этап 13)
  PRICED // цены проставлены (этап 13)
  SIGNED // подписанный акт приложен (этап 14)
}

model User {
  id           String   @id @default(uuid())
  login        String   @unique // латиница, вводится при входе
  passwordHash String // argon2id, см. src/lib/password.ts
  name         String // «Милена», «Алексей Писарев»
  phone        String?
  role         Role
  isActive     Boolean  @default(true)
  canLogin     Boolean  @default(true) // false — внешний исполнитель (Султан): входа нет, задачи на него ведёт диспетчер
  createdAt    DateTime @default(now())

  tasks        Task[]             @relation("assignee")
  createdTasks Task[]             @relation("creator")
  events       TaskEvent[]
  pushSubs     PushSubscription[] // этап 5 (web-push): подписки устройств этого пользователя

  // KPI / зарплата (Фаза 1.5, ARCHITECTURE §4а)
  kpiMarks        KpiMark[]          @relation("kpiDriver") // отметки KPI этого водителя
  kpiCreatedMarks KpiMark[]          @relation("kpiCreatedBy") // ручные отметки, созданные этим диспетчером
  payProfile      DriverPayProfile?  @relation("payProfile") // денежный профиль (только водители)
  payStatements   PayrollStatement[] @relation("payStatements") // закрытые расчёты за месяцы
}

// Справочник типов задач (PRD §3). Новые типы заводит админ без правки кода.
model TaskType {
  id                String  @id @default(uuid())
  name              String  @unique // «Доставка в аренду», «Забор в ремонт»...
  icon              String? // имя иконки lucide
  requiresPhoto     Boolean @default(true) // обязательное фото при DONE (проверка на сервере — этап 4)
  // Ремонтный тип: ожидается подписанный акт (документ-вложение). НЕ гейт завершения —
  // отсутствие = нарушение KPI UNSIGNED_DOCS (Фаза 1.5, PRD §12.1). См. src/domain/kpi.ts.
  requiresSignedDoc Boolean @default(false)
  // Нужна ли ведомость работ + расценка (этап 12, PRD §13): выездной ремонт/диагностика, гарантия.
  // Акты-описи (аренда/забор) ведомость не используют, поэтому это отдельный флаг от requiresSignedDoc.
  requiresPricing   Boolean @default(false)
  sortOrder         Int     @default(0)
  isActive          Boolean @default(true)
  tasks             Task[]
}

model Task {
  id     String @id @default(uuid())
  // Сквозной номер: Postgres sequence task_number_seq (START 476 — миграция). См. ARCHITECTURE §4.
  number Int    @unique @default(dbgenerated("nextval('task_number_seq'::regclass)"))

  typeId String
  type   TaskType @relation(fields: [typeId], references: [id])

  // Требование подписанного акта НА УРОВНЕ ЗАДАЧИ (этап 11, PRD §4): снимок дефолта из
  // type.requiresSignedDoc при создании; диспетчер может снять галочкой «акт не нужен»
  // (actWaivedNote — причина, напр. «подпишут по ЭДО»). Источник для KPI UNSIGNED_DOCS — теперь
  // это поле, не type (см. src/domain/kpi-service.ts). НЕ гейт завершения (PRD §5).
  requiresSignedDoc Boolean @default(false)
  actWaivedNote     String? // причина снятия требования акта на этой заявке
  // Ведомость работ (этап 12): null — не нужна (тип без requiresPricing); иначе DRAFT→PRICING→PRICED→SIGNED.
  worksheetStatus   WorksheetStatus?

  title         String // «ЛБМ 200 + нож + дог. маш, 0,7 мм»
  description   String?     @db.Text
  equipment     String? // «ЛБМ 250», «Sorex 2 м»
  orgName       String? // «ДОМОСТРОЙ ЛОГИСТИК ООО»
  contactName   String?
  contactPhone  String?
  address       String
  addressLink   String? // deeplink Яндекс/2ГИС
  invoiceNumber String? // «948», «261»
  paymentType   PaymentType @default(NONE)
  paymentAmount Int? // «доставка 5000 водителю»
  paymentNote   String?
  scheduledDate DateTime?   @db.Date // null — пул «Без даты»
  timeFrom      String? // «09:00»
  timeTo        String? // «17:00»
  timeNote      String? // «после обеда»
  passStatus    PassStatus  @default(NOT_NEEDED)
  priority      Boolean     @default(false) // срочная
  status        TaskStatus  @default(NEW)

  assigneeId  String?
  assignee    User?   @relation("assignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User    @relation("creator", fields: [createdById], references: [id])

  cancelReason String?
  holdReason   String?

  events      TaskEvent[]
  attachments Attachment[]
  workItems   WorkItem[] // позиции ведомости работ (этап 12)
  kpiMarks    KpiMark[] // отметки KPI, привязанные к этой задаче (Фаза 1.5)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([assigneeId, scheduledDate])
  @@index([status, scheduledDate])
}

// Неизменяемый журнал событий (CLAUDE.md правило 3): только на запись, не редактируется и не удаляется.
model TaskEvent {
  id         String      @id @default(uuid())
  taskId     String
  task       Task        @relation(fields: [taskId], references: [id])
  actorId    String
  actor      User        @relation(fields: [actorId], references: [id])
  kind       String // status_change | comment | edit | assign | reschedule | created
  fromStatus TaskStatus?
  toStatus   TaskStatus?
  comment    String?
  lat        Float?
  lng        Float?
  at         DateTime    @default(now())

  @@index([taskId, at])
}

// Вложения задачи (ARCHITECTURE §4, §6). Фото-отчёты исполнителя и вложения диспетчера при
// постановке различаются по createdById. Файлы лежат в UPLOADS_DIR (vol), путь — серверный
// uuid.ext (клиент имя не задаёт). Раздача — только через GET /api/attachments/:id с проверкой
// прав, не из public/. Привязка к задаче определяет, кто имеет доступ (та же изоляция).
model Attachment {
  id          String         @id @default(uuid())
  taskId      String
  task        Task           @relation(fields: [taskId], references: [id])
  kind        AttachmentKind @default(PHOTO)
  filePath    String // относительный путь в UPLOADS_DIR (uuid.ext) — генерит сервер
  mimeType    String
  sizeBytes   Int
  createdById String // кто загрузил: отчётные — исполнитель (assignee), при постановке — диспетчер
  lat         Float?
  lng         Float?
  createdAt   DateTime       @default(now())

  @@index([taskId, createdAt])
}

// Справочник работ для ведомости (этап 12, PRD §13.3). Наполняет админ. Цены-подсказки — этап 13.
model WorkCatalogItem {
  id        String     @id @default(uuid())
  name      String     @unique // «Диагностика», «Замена ножа»...
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  workItems WorkItem[]
}

// Позиция ведомости выполненных работ (этап 12, PRD §13.1). Водитель фиксирует ЧТО сделал и
// количество — БЕЗ цен. Цену проставляет диспетчер при расценке (этап 13). Меняется водителем
// только пока worksheetStatus=DRAFT. catalogItemId=null — свободная строка (работы нет в справочнике).
model WorkItem {
  id            String           @id @default(uuid())
  taskId        String
  task          Task             @relation(fields: [taskId], references: [id])
  catalogItemId String?
  catalogItem   WorkCatalogItem? @relation(fields: [catalogItemId], references: [id])
  name          String // снимок названия работы (из справочника или свободный ввод)
  quantity      Int              @default(1)
  sortOrder     Int              @default(0)
  createdById   String // водитель, заполнивший позицию
  createdAt     DateTime         @default(now())

  @@index([taskId, sortOrder])
}

// Подписка устройства на web-push (ARCHITECTURE §4, §8). Одна запись = один браузер/устройство
// пользователя. endpoint уникален. Протухшие подписки (HTTP 404/410 при отправке) сервис удаляет.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String // ключ шифрования из subscription.keys.p256dh
  auth      String // ключ аутентификации из subscription.keys.auth
  userAgent String? // для отладки/опознания устройства
  createdAt DateTime @default(now())

  @@index([userId])
}

// ───────────────────────────── KPI и зарплата (Фаза 1.5) ─────────────────────────────
// Модель данных — ARCHITECTURE §4а, продукт — PRD §12. Всё аддитивно поверх Фазы 1.
// Принцип: зарплата = оклад + (премия − прогрессивные штрафы) + ручные поощрения; закрытый
// месяц фиксируется снимком (PayrollStatement) и больше не зависит от правок отметок/правил.

// Виды отметок KPI: 3 авто-метрики (детектор) + ручная отметка диспетчера.
enum KpiMarkKind {
  LATE // опоздание: «На месте» позже timeTo задачи (PRD §12.1)
  UNSIGNED_DOCS // ремонтная задача завершена без подписанного акта (документ-вложения)
  MISSED_STOP // назначенная на день точка не доведена до DONE (без переноса/отмены)
  MANUAL // ручная отметка: штраф или поощрение (знаковая сумма в manualAmount)
}

// Жизненный цикл отметки: предложено системой → решение Милены. Ручные сразу CONFIRMED.
enum KpiMarkStatus {
  CANDIDATE
  CONFIRMED
  DISMISSED
}

// Нижний порог итога к выплате (решение Артёма, KPI-ответ 1): SALARY — штрафы максимум
// обнуляют премию, итог не ниже оклада. ZERO — премия может уйти в минус (итог не ниже 0).
enum PayoutFloor {
  SALARY
  ZERO
}

// Отметка KPI. Авто-кандидатов создаёт ночной детектор (cron), решение принимает диспетчер.
// Корректируемый реестр (в отличие от неизменяемого TaskEvent): пока месяц открыт, статус
// можно менять — каждое решение пишет resolvedById/resolvedAt. Закрытый месяц фиксируется
// снимком в PayrollStatement и больше не зависит от правок отметок (PRD §12.4).
model KpiMark {
  id           String        @id @default(uuid())
  driverId     String // чей KPI; изоляция водителя — по нему
  driver       User          @relation("kpiDriver", fields: [driverId], references: [id])
  taskId       String? // привязка к задаче (LATE/UNSIGNED_DOCS/MISSED_STOP); null — ручная общая
  task         Task?         @relation(fields: [taskId], references: [id])
  period       String // месяц начисления «YYYY-MM» (по occurredAt в CRON_TZ)
  kind         KpiMarkKind
  status       KpiMarkStatus @default(CANDIDATE)
  occurredAt   DateTime // когда произошло — для прогрессии (порядок ошибок в месяце)
  note         String? // автоописание / пояснение диспетчера
  manualAmount Int? // только MANUAL: знаковая сумма ₽ (− штраф, + поощрение)
  createdById  String? // null — авто-кандидат от системы; иначе диспетчер (ручная)
  createdBy    User?         @relation("kpiCreatedBy", fields: [createdById], references: [id])
  resolvedById String? // кто подтвердил/отклонил (uuid, без навигации — см. §4а)
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())

  @@unique([taskId, kind]) // идемпотентность детектора: одна авто-отметка вида на задачу
  @@index([driverId, period])
  @@index([status, period])
}

// Денежный профиль водителя (оклад/премия задаёт админ). Веса штрафов — глобальные (KpiRule),
// шаг прогрессии и нижний порог — глобальные (KpiSettings).
model DriverPayProfile {
  id          String   @id @default(uuid())
  driverId    String   @unique
  driver      User     @relation("payProfile", fields: [driverId], references: [id])
  baseSalary  Int      @default(0) // оклад ₽/мес
  premiumBase Int      @default(0) // премия ₽ при нуле ошибок (полная «прибавка»)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// Глобальный вес штрафа по виду нарушения (по строке на авто-метрику). Настраивает админ.
model KpiRule {
  id       String      @id @default(uuid())
  kind     KpiMarkKind @unique
  weight   Int // базовый штраф ₽ за ошибку этого вида (до прогрессии)
  isActive Boolean     @default(true)
}

// Глобальные настройки расчёта (singleton, одна строка). Шаг прогрессии вынесен из константы
// в БД, потому что админ настраивает прогрессию в UI (PRD §8 экран 5, решение Артёма). Это
// осознанное уточнение ARCHITECTURE §4а («шаг прогрессии — константа») — зафиксировано в доке.
model KpiSettings {
  id                    String      @id @default("singleton") // ровно одна строка
  progressionPercent    Int         @default(110) // шаг прогрессии, % (110 = ×1.10 на каждую следующую ошибку)
  progressionStartIndex Int         @default(3) // с какого по счёту нарушения месяца включается прогрессия
  floor                 PayoutFloor @default(SALARY) // нижний порог итога (решение Артёма)
  updatedAt             DateTime    @updatedAt
}

// Снимок расчёта за закрытый месяц (неизменяем). До закрытия расчёт считается на лету из
// CONFIRMED-отметок + правил + настроек. После закрытия — отдаётся этот снимок (PRD §12.4).
model PayrollStatement {
  id          String   @id @default(uuid())
  driverId    String
  driver      User     @relation("payStatements", fields: [driverId], references: [id])
  period      String // «YYYY-MM»
  baseSalary  Int // снимок оклада
  premiumBase Int // снимок премии
  penalty     Int // сумма штрафов (положительное число)
  bonus       Int // сумма ручных поощрений
  total       Int // итог к выплате (не ниже нижнего порога)
  breakdown   Json // детализация по отметкам на момент закрытия
  closedById  String // кто закрыл (uuid, без навигации)
  closedAt    DateTime @default(now())

  @@unique([driverId, period])
}
