// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Роли (ARCHITECTURE §4). Источник правды по правам — только сессия, см. §6.
enum Role {
  ADMIN
  DISPATCHER
  DRIVER
}

// Статусы задачи (ARCHITECTURE §5). Переходы — только через матрицу в src/domain/task-status.ts.
// Переработка механики водителя (этап A): рабочая цепочка схлопнута в IN_PROGRESS «В работе»
// (объединяет прежние ACCEPTED+EN_ROUTE+ON_SITE). ACCEPTED/EN_ROUTE/ON_SITE — LEGACY: новым задачам
// не назначаются, оставлены в enum ради чтения неизменяемого журнала TaskEvent (CLAUDE.md правило 3).
enum TaskStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  ACCEPTED // legacy (до этапа A)
  EN_ROUTE // legacy (до этапа A)
  ON_SITE // legacy (до этапа A)
  DONE
  ON_HOLD
  RESCHEDULED
  CANCELLED
}

// Статус пропуска на объект (PRD §6).
enum PassStatus {
  NOT_NEEDED
  NEEDED
  ORDERED
}

// Оплата (PRD §4): нет / через офис / на месте.
enum PaymentType {
  NONE
  OFFICE
  ON_SITE
}

// Вид вложения (ARCHITECTURE §4). Фото — отчётные и приложенные при постановке.
enum AttachmentKind {
  PHOTO
  DOCUMENT
}

// Состояние ведомости работ (этап 12, PRD §13.4). На задаче null — ведомость не нужна
// (тип без requiresPricing). Жизненный цикл живёт отдельно от статуса задачи.
enum WorksheetStatus {
  DRAFT // водитель заполняет
  PRICING // отправлена диспетчеру на расценку (этап 13)
  PRICED // цены проставлены (этап 13)
  SIGNED // подписанный акт приложен (этап 14)
}

// Смена водителя (этап C, переработка механики). Водитель «открывает смену» (фактическое начало дня) →
// диспетчер подтверждает приход (он физически на базе) → водитель «закрывает смену» (конец дня).
enum ShiftStatus {
  REQUESTED // открыта водителем, ждёт подтверждения диспетчера
  OPEN // диспетчер подтвердил — смена идёт
  CLOSED // водитель закрыл смену
}

// Тип отсутствия водителя (№9, решение Артёма 23.06): отпуск / больничный / прочее.
enum AbsenceType {
  VACATION // отпуск
  SICK // больничный
  OTHER // прочее (отгул и т.п.)
}

model User {
  id             String               @id @default(uuid())
  login          String               @unique // латиница, вводится при входе
  passwordHash   String // argon2id, см. src/lib/password.ts
  name           String // «Милена», «Алексей Писарев»
  // Должность для отображения в шапке (напр. «Директор» у Михаила при role=ADMIN). НЕ право:
  // права определяет role. null → подпись берётся по роли (roleLabel). Решение Артёма 23.06.2026.
  position       String?
  phone          String?
  role           Role
  isActive       Boolean              @default(true)
  canLogin       Boolean              @default(true) // false — внешний исполнитель (Султан): входа нет, задачи на него ведёт диспетчер
  // Ёмкость (Фаза 2, PRD §14.5): специализация для подсказки «кто свободен». Каширский REPAIR, Писарев/Султан DELIVERY.
  specialization DriverSpecialization @default(ANY)
  createdAt      DateTime             @default(now())

  tasks        Task[]             @relation("assignee")
  createdTasks Task[]             @relation("creator")
  events       TaskEvent[]
  pushSubs     PushSubscription[] // этап 5 (web-push): подписки устройств этого пользователя

  // KPI / зарплата (Фаза 1.5, ARCHITECTURE §4а)
  kpiMarks        KpiMark[]          @relation("kpiDriver") // отметки KPI этого водителя
  kpiCreatedMarks KpiMark[]          @relation("kpiCreatedBy") // ручные отметки, созданные этим диспетчером
  payProfile      DriverPayProfile?  @relation("payProfile") // денежный профиль (только водители)
  payStatements   PayrollStatement[] @relation("payStatements") // закрытые расчёты за месяцы
  uiPrefs         UiPreference[] // настройки интерфейса (раскладка доски/планирования)
  shifts          Shift[]            @relation("shiftDriver") // смены водителя (этап C)
  absences        DriverAbsence[]    @relation("driverAbsence") // отпуска/больничные водителя (№9)
}

// Справочник типов задач (PRD §3). Новые типы заводит админ без правки кода.
model TaskType {
  id                String  @id @default(uuid())
  name              String  @unique // «Доставка в аренду», «Забор в ремонт»...
  icon              String? // имя иконки lucide
  requiresPhoto     Boolean @default(true) // обязательное фото при DONE (проверка на сервере — этап 4)
  // Ремонтный тип: ожидается подписанный акт (документ-вложение). НЕ гейт завершения —
  // отсутствие = нарушение KPI UNSIGNED_DOCS (Фаза 1.5, PRD §12.1). См. src/domain/kpi.ts.
  requiresSignedDoc Boolean @default(false)
  // Нужна ли ведомость работ + расценка (этап 12, PRD §13): выездной ремонт/диагностика, гарантия.
  // Акты-описи (аренда/забор) ведомость не используют, поэтому это отдельный флаг от requiresSignedDoc.
  requiresPricing   Boolean @default(false)
  // Ёмкость (Фаза 2, PRD §14.2): норма работы на объекте, мин (сверх времени на дорогу).
  onSiteMinutes     Int     @default(30)
  sortOrder         Int     @default(0)
  isActive          Boolean @default(true)
  tasks             Task[]
}

model Task {
  id     String @id @default(uuid())
  // Сквозной номер: Postgres sequence task_number_seq (START 476 — миграция). См. ARCHITECTURE §4.
  number Int    @unique @default(dbgenerated("nextval('task_number_seq'::regclass)"))

  typeId String
  type   TaskType @relation(fields: [typeId], references: [id])

  // Требование подписанного акта НА УРОВНЕ ЗАДАЧИ (этап 11, PRD §4): снимок дефолта из
  // type.requiresSignedDoc при создании; диспетчер может снять галочкой «акт не нужен»
  // (actWaivedNote — причина, напр. «подпишут по ЭДО»). Источник для KPI UNSIGNED_DOCS — теперь
  // это поле, не type (см. src/domain/kpi-service.ts). НЕ гейт завершения (PRD §5).
  requiresSignedDoc Boolean          @default(false)
  actWaivedNote     String? // причина снятия требования акта на этой заявке
  // Ведомость работ (этап 12): null — не нужна (тип без requiresPricing); иначе DRAFT→PRICING→PRICED→SIGNED.
  worksheetStatus   WorksheetStatus?

  title            String // «ЛБМ 200 + нож + дог. маш, 0,7 мм»
  description      String?     @db.Text
  equipment        String? // «ЛБМ 250», «Sorex 2 м»
  orgName          String? // «ДОМОСТРОЙ ЛОГИСТИК ООО»
  contactName      String?
  contactPhone     String?
  address          String
  addressLink      String? // deeplink Яндекс/2ГИС
  invoiceNumber    String? // «948», «261»
  paymentType      PaymentType @default(NONE)
  paymentAmount    Int? // «доставка 5000 водителю»
  paymentNote      String?
  // Факт оплаты при завершении ON_SITE-задачи (№8, решение Артёма 23.06): true — деньги получены,
  // false — завершена без оплаты (с причиной paymentMissedReason), null — не относится / нет данных.
  paymentReceived     Boolean?
  paymentMissedReason String? // причина неоплаты (типовой вариант или свой текст), если paymentReceived=false
  scheduledDate    DateTime?   @db.Date // null — пул «Без даты»
  timeFrom         String? // «09:00»
  timeTo           String? // «17:00»
  timeNote         String? // «после обеда»
  // Ёмкость и оценка времени (Фаза 2, PRD §14). lat/lng — геокод адреса при создании/правке
  // (src/lib/geocode.ts); null — геокод не удался (оценка считается без дороги).
  lat              Float?
  lng              Float?
  estimatedMinutes Int? // оценка времени, мин (норма типа + дорога); null — не посчитана
  estimateIsManual Boolean     @default(false) // диспетчер задал оценку вручную → не пересчитывать
  passStatus       PassStatus  @default(NOT_NEEDED)
  priority         Boolean     @default(false) // срочная
  status           TaskStatus  @default(NEW)

  assigneeId  String?
  assignee    User?   @relation("assignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User    @relation("creator", fields: [createdById], references: [id])

  cancelReason String?
  holdReason   String?

  events      TaskEvent[]
  attachments Attachment[]
  workItems   WorkItem[] // позиции ведомости работ (этап 12)
  kpiMarks    KpiMark[] // отметки KPI, привязанные к этой задаче (Фаза 1.5)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([assigneeId, scheduledDate])
  @@index([status, scheduledDate])
}

// Неизменяемый журнал событий (CLAUDE.md правило 3): только на запись, не редактируется и не удаляется.
model TaskEvent {
  id         String      @id @default(uuid())
  taskId     String
  task       Task        @relation(fields: [taskId], references: [id])
  actorId    String
  actor      User        @relation(fields: [actorId], references: [id])
  kind       String // status_change | comment | edit | assign | reschedule | created
  fromStatus TaskStatus?
  toStatus   TaskStatus?
  comment    String?
  lat        Float?
  lng        Float?
  at         DateTime    @default(now())

  @@index([taskId, at])
}

// Вложения задачи (ARCHITECTURE §4, §6). Фото-отчёты исполнителя и вложения диспетчера при
// постановке различаются по createdById. Файлы лежат в UPLOADS_DIR (vol), путь — серверный
// uuid.ext (клиент имя не задаёт). Раздача — только через GET /api/attachments/:id с проверкой
// прав, не из public/. Привязка к задаче определяет, кто имеет доступ (та же изоляция).
model Attachment {
  id          String         @id @default(uuid())
  taskId      String
  task        Task           @relation(fields: [taskId], references: [id])
  kind        AttachmentKind @default(PHOTO)
  filePath    String // относительный путь в UPLOADS_DIR (uuid.ext) — генерит сервер
  mimeType    String
  sizeBytes   Int
  createdById String // кто загрузил: отчётные — исполнитель (assignee), при постановке — диспетчер
  lat         Float?
  lng         Float?
  createdAt   DateTime       @default(now())

  @@index([taskId, createdAt])
}

// Раздел справочника работ (группа услуг/товаров). Наполняет админ; позиции группируются по
// разделам в выборе у водителя и в админке. Позиция может быть без раздела (categoryId=null).
model WorkCategory {
  id        String            @id @default(uuid())
  name      String            @unique // «Услуги», «Запчасти / товары»...
  sortOrder Int               @default(0)
  isActive  Boolean           @default(true)
  items     WorkCatalogItem[]
}

// Справочник работ для ведомости (этап 12, PRD §13.3). Наполняет админ. Цены-подсказки — этап 13.
model WorkCatalogItem {
  id           String        @id @default(uuid())
  name         String        @unique // «Диагностика», «Замена ножа»...
  defaultPrice Int? // подсказка цены за единицу, ₽ (этап 13); диспетчер правит при расценке
  categoryId   String? // раздел справочника (группа); null — без раздела
  category     WorkCategory? @relation(fields: [categoryId], references: [id])
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  workItems    WorkItem[]
}

// Позиция ведомости выполненных работ (этап 12, PRD §13.1). Водитель фиксирует ЧТО сделал и
// количество — БЕЗ цен. Цену проставляет диспетчер при расценке (этап 13). Меняется водителем
// только пока worksheetStatus=DRAFT. catalogItemId=null — свободная строка (работы нет в справочнике).
model WorkItem {
  id            String           @id @default(uuid())
  taskId        String
  task          Task             @relation(fields: [taskId], references: [id])
  catalogItemId String?
  catalogItem   WorkCatalogItem? @relation(fields: [catalogItemId], references: [id])
  name          String // снимок названия работы (из справочника или свободный ввод)
  quantity      Int              @default(1)
  price         Int? // цена за единицу, ₽ (этап 13): null пока диспетчер не расценил
  sortOrder     Int              @default(0)
  createdById   String // водитель, заполнивший позицию
  createdAt     DateTime         @default(now())

  @@index([taskId, sortOrder])
}

// Подписка устройства на web-push (ARCHITECTURE §4, §8). Одна запись = один браузер/устройство
// пользователя. endpoint уникален. Протухшие подписки (HTTP 404/410 при отправке) сервис удаляет.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String // ключ шифрования из subscription.keys.p256dh
  auth      String // ключ аутентификации из subscription.keys.auth
  userAgent String? // для отладки/опознания устройства
  createdAt DateTime @default(now())

  @@index([userId])
}

// Смена водителя (этап C). «Открыть смену» фиксирует фактическое начало рабочего дня (момент нажатия
// водителя), диспетчер подтверждает приход (он на базе). «Закрыть смену» — конец дня. Одна смена на
// водителя в день. Время начала/конца — основа учёта отработанного и простоя (этап D). Изоляция как у
// задач: driverId берётся ТОЛЬКО из сессии (CLAUDE.md правило 1). confirmedById — uuid без навигации.
model Shift {
  id            String      @id @default(uuid())
  driverId      String
  driver        User        @relation("shiftDriver", fields: [driverId], references: [id])
  date          DateTime    @db.Date // рабочий день — локальная дата открытия (МСК)
  status        ShiftStatus @default(REQUESTED)
  openedAt      DateTime // фактическое время начала смены; может быть скорректировано диспетчером/админом (№3)
  // Корректировка времени открытия (№3, решение Артёма 23.06): на случай «не было связи / сел телефон».
  // В openedAt держим АКТУАЛЬНОЕ (исправленное) — KPI/учёт считают по нему; здесь — аудит правки.
  openedAtReported     DateTime? // исходное время (что нажал водитель), снимок до первой правки; null = не правили
  openedAtAdjustedById String? // кто поправил (диспетчер/админ), uuid без навигации
  openedAtAdjustedAt   DateTime?
  openedAtAdjustNote   String? // причина правки (напр. «не было связи»)
  confirmedById String? // диспетчер, подтвердивший открытие
  confirmedAt   DateTime?
  closedAt      DateTime?
  createdAt     DateTime    @default(now())
  kpiMarks      KpiMark[] // отметки KPI по смене (SHIFT_LATE, этап D)

  @@unique([driverId, date]) // одна смена на водителя в день
  @@index([date, status])
}

// Отсутствие водителя (№9, решение Артёма 23.06): отпуск/больничный/прочее на диапазон дат.
// Заводят админ и диспетчер. Влияет на Календарь загрузки (дни «гасятся») и KPI (в отпуск не штрафуем
// «невыполненную точку»). driverId — за другого (исключение из изоляции): валидируется как DRIVER в сервисе.
model DriverAbsence {
  id          String      @id @default(uuid())
  driverId    String
  driver      User        @relation("driverAbsence", fields: [driverId], references: [id])
  dateFrom    DateTime    @db.Date // включительно
  dateTo      DateTime    @db.Date // включительно
  type        AbsenceType @default(VACATION)
  note        String?
  createdById String? // кто завёл (uuid без навигации, как принято)
  createdAt   DateTime    @default(now())

  @@index([driverId, dateFrom])
  @@index([dateFrom, dateTo])
}

// ───────────────────────────── KPI и зарплата (Фаза 1.5) ─────────────────────────────
// Модель данных — ARCHITECTURE §4а, продукт — PRD §12. Всё аддитивно поверх Фазы 1.
// Принцип: зарплата = оклад + (премия − прогрессивные штрафы) + ручные поощрения; закрытый
// месяц фиксируется снимком (PayrollStatement) и больше не зависит от правок отметок/правил.

// Виды отметок KPI: 3 авто-метрики (детектор) + ручная отметка диспетчера.
enum KpiMarkKind {
  SHIFT_LATE // поздно открыл смену (этап D): openedAt позже порога 9:15. Заменяет LATE
  LATE // legacy: опоздание на объект (до этапа D); новых не создаётся, остаётся в истории
  UNSIGNED_DOCS // ремонтная задача завершена без подписанного акта (документ-вложения)
  MISSED_STOP // назначенная на день точка не доведена до DONE (без переноса/отмены)
  MANUAL // ручная отметка: штраф или поощрение (знаковая сумма в manualAmount)
}

// Жизненный цикл отметки: предложено системой → решение Милены. Ручные сразу CONFIRMED.
enum KpiMarkStatus {
  CANDIDATE
  CONFIRMED
  DISMISSED
}

// Нижний порог итога к выплате (решение Артёма, KPI-ответ 1): SALARY — штрафы максимум
// обнуляют премию, итог не ниже оклада. ZERO — премия может уйти в минус (итог не ниже 0).
enum PayoutFloor {
  SALARY
  ZERO
}

// Отметка KPI. Авто-кандидатов создаёт ночной детектор (cron), решение принимает диспетчер.
// Корректируемый реестр (в отличие от неизменяемого TaskEvent): пока месяц открыт, статус
// можно менять — каждое решение пишет resolvedById/resolvedAt. Закрытый месяц фиксируется
// снимком в PayrollStatement и больше не зависит от правок отметок (PRD §12.4).
model KpiMark {
  id           String        @id @default(uuid())
  driverId     String // чей KPI; изоляция водителя — по нему
  driver       User          @relation("kpiDriver", fields: [driverId], references: [id])
  taskId       String? // привязка к задаче (UNSIGNED_DOCS/MISSED_STOP); null — смена/ручная
  task         Task?         @relation(fields: [taskId], references: [id])
  shiftId      String? // привязка к смене (SHIFT_LATE, этап D); null — задачная/ручная
  shift        Shift?        @relation(fields: [shiftId], references: [id])
  period       String // месяц начисления «YYYY-MM» (по occurredAt в CRON_TZ)
  kind         KpiMarkKind
  status       KpiMarkStatus @default(CANDIDATE)
  occurredAt   DateTime // когда произошло — для прогрессии (порядок ошибок в месяце)
  note         String? // автоописание / пояснение диспетчера
  manualAmount Int? // только MANUAL: знаковая сумма ₽ (− штраф, + поощрение)
  createdById  String? // null — авто-кандидат от системы; иначе диспетчер (ручная)
  createdBy    User?         @relation("kpiCreatedBy", fields: [createdById], references: [id])
  resolvedById String? // кто подтвердил/отклонил (uuid, без навигации — см. §4а)
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())

  @@unique([taskId, kind]) // идемпотентность детектора: одна авто-отметка вида на задачу
  @@unique([shiftId, kind]) // идемпотентность детектора смен: одна SHIFT_LATE на смену (этап D)
  @@index([driverId, period])
  @@index([status, period])
}

// Денежный профиль водителя (оклад/премия задаёт админ). Веса штрафов — глобальные (KpiRule),
// шаг прогрессии и нижний порог — глобальные (KpiSettings).
model DriverPayProfile {
  id          String   @id @default(uuid())
  driverId    String   @unique
  driver      User     @relation("payProfile", fields: [driverId], references: [id])
  baseSalary  Int      @default(0) // оклад ₽/мес
  premiumBase Int      @default(0) // премия ₽ при нуле ошибок (полная «прибавка»)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// Глобальный вес штрафа по виду нарушения (по строке на авто-метрику). Настраивает админ.
model KpiRule {
  id       String      @id @default(uuid())
  kind     KpiMarkKind @unique
  weight   Int // базовый штраф ₽ за ошибку этого вида (до прогрессии)
  isActive Boolean     @default(true)
}

// Глобальные настройки расчёта (singleton, одна строка). Шаг прогрессии вынесен из константы
// в БД, потому что админ настраивает прогрессию в UI (PRD §8 экран 5, решение Артёма). Это
// осознанное уточнение ARCHITECTURE §4а («шаг прогрессии — константа») — зафиксировано в доке.
model KpiSettings {
  id                       String      @id @default("singleton") // ровно одна строка
  progressionPercent       Int         @default(110) // шаг прогрессии, % (110 = ×1.10 на каждую следующую ошибку)
  progressionStartIndex    Int         @default(3) // с какого по счёту нарушения месяца включается прогрессия
  floor                    PayoutFloor @default(SALARY) // нижний порог итога (решение Артёма)
  actBonusAmount           Int         @default(5000) // бонус за комплектность актов, ₽ (этап 15, PRD §12.6)
  actBonusThresholdPercent Int         @default(80) // порог комплектности актов для бонуса, % (этап 15)
  updatedAt                DateTime    @updatedAt
}

// Снимок расчёта за закрытый месяц (неизменяем). До закрытия расчёт считается на лету из
// CONFIRMED-отметок + правил + настроек. После закрытия — отдаётся этот снимок (PRD §12.4).
model PayrollStatement {
  id          String   @id @default(uuid())
  driverId    String
  driver      User     @relation("payStatements", fields: [driverId], references: [id])
  period      String // «YYYY-MM»
  baseSalary  Int // снимок оклада
  premiumBase Int // снимок премии
  penalty     Int // сумма штрафов (положительное число)
  bonus       Int // сумма ручных поощрений
  actBonus    Int      @default(0) // бонус за комплектность актов (этап 15, PRD §12.6): 0 или actBonusAmount
  actBase     Int      @default(0) // знаменатель: завершённые актовые задачи месяца (снимок)
  actComplete Int      @default(0) // числитель: из них с приложенным актом (снимок)
  total       Int // итог к выплате (не ниже нижнего порога; включает actBonus)
  breakdown   Json // детализация по отметкам на момент закрытия
  closedById  String // кто закрыл (uuid, без навигации)
  closedAt    DateTime @default(now())

  @@unique([driverId, period])
}

// ───────────────────────── Ёмкость и календарь загрузки (Фаза 2) ─────────────────────────
// Модель — ARCHITECTURE §4б, продукт — PRD §14. Аддитивно. Оценка времени задачи = норма типа
// (TaskType.onSiteMinutes) + дорога (haversine база→точка × петляние ÷ скорость × коэфф. пробок).
// Маршрут с живыми пробками не подключаем (PRD §14.6). Чистый расчёт — src/domain/capacity.ts.

// Специализация водителя для подсказки «кто свободен» (PRD §14.5). «Ремонтность» задачи берём из
// type.requiresPricing (выездной ремонт + гарантия); это поле — предпочтение водителя.
enum DriverSpecialization {
  REPAIR // выездные ремонты (Каширский)
  DELIVERY // доставки (Писарев, Султан)
  ANY // без выраженной специализации
}

// Глобальные настройки расчёта ёмкости (singleton, одна строка), как KpiSettings. Дефолты —
// данные Артёма 19.06.2026. Правит админ в UI.
model CapacitySettings {
  id              String   @id @default("singleton")
  baseLat         Float    @default(55.959611) // база: пос. Лесные Поляны, ул. Ленина 1Ас26
  baseLng         Float    @default(37.864076)
  workdayMinutes  Int      @default(480) // рабочий день минус обед (9–18 − 1 ч) — знаменатель загрузки
  avgSpeedKmh     Int      @default(50) // средняя скорость свободной дороги, км/ч; калибруется по факту
  detourPercent   Int      @default(110) // коэфф. петляния (110 = ×1.1)
  countReturnTrip Boolean  @default(false) // учитывать обратную дорогу (база→точка→база)
  // Смена (этап D): порог «поздно открыл смену». shiftStartMinutes — начало рабочего дня (минуты от
  // полуночи: 540 = 9:00); shiftLateGraceMinutes — запас (15 мин → опоздание после 9:15).
  shiftStartMinutes     Int @default(540)
  shiftLateGraceMinutes Int @default(15)
  updatedAt       DateTime @updatedAt
}

// Коэффициент пробок по окну времени суток (PRD §14.3). Набор строк, как KpiRule. Настраивает админ.
// Окна не пересекаются и покрывают сутки; factor берётся по timeFrom задачи (нет времени → дневное окно).
model TrafficWindow {
  id            String @id @default(uuid())
  fromMinutes   Int // минуты от полуночи: 04:00 = 240
  toMinutes     Int // 07:00 = 420
  factorPercent Int // 100 = ×1.0 … 140 = ×1.4
  sortOrder     Int    @default(0)
}

// Настройки интерфейса пользователя: персональная раскладка экранов диспетчера (порядок пулов на
// доске/планировании и свёрнутые пулы). Привязка к пользователю — раскладка одинакова на любом его
// устройстве. Личность пишется ТОЛЬКО из сессии (CLAUDE.md правило 1). value — JSON-массив строк
// (ключи пулов в нужном порядке / свёрнутые ключи). Ключи допустимых настроек — в src/domain/ui-prefs.ts.
model UiPreference {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String // "board.order" | "board.collapsed" | "planning.order"
  value     Json // string[]
  updatedAt DateTime @updatedAt

  @@id([userId, key])
}
