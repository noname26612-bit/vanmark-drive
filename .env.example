# Шаблон переменных окружения. Скопируй в .env и при необходимости поправь.

# PostgreSQL (локально поднимается через `pnpm db:up`, см. docker-compose.yml)
DATABASE_URL="postgresql://vanmark:vanmark@localhost:5432/vanmark?schema=public"

# Auth.js (этап 1)
AUTH_SECRET=                   # секрет JWT-сессии: openssl rand -base64 32
AUTH_TRUST_HOST=true           # self-hosted деплой (не Vercel): доверяем Host-заголовку за Caddy

# Сид пользователей (этап 1): пароль, которым хэшируются учётки из prisma/seed.ts.
# Локально — любой; на проде задать стойкий и не коммитить.
SEED_PASSWORD="vanmark123"
# Индивидуальные пароли для безопасного прод-сидера ростера (`pnpm db:seed:roster`, prisma/seed-roster.ts):
# при создании Николая (подменный водитель) и Михаила (директор, права ADMIN). Если не заданы — берётся
# общий SEED_PASSWORD. На проде задать стойкие и не коммитить.
SEED_PASSWORD_NIKOLAY=
SEED_PASSWORD_MIKHAIL=

# Хранение фото-отчётов (Этап 4). Локальный том; вне раздачи статикой (отдаём через
# GET /api/attachments/:id с проверкой прав). Папка в .gitignore.
UPLOADS_DIR=./data/uploads

# Web Push (Этап 5). VAPID-пара: `npx web-push generate-vapid-keys` или node-скрипт (P-256).
# Публичный ключ дублируется в NEXT_PUBLIC_VAPID_PUBLIC_KEY (он уезжает в браузер для подписки).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@van-mark.ru
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Планировщик напоминаний (node-cron, ARCHITECTURE §8). Таймзона cron-задач 08:00/16:00.
CRON_TZ=Europe/Moscow

# Геокодер адреса (Фаза 2, ARCHITECTURE §4б, src/lib/geocode.ts). Превращает адрес задачи в
# координаты для оценки времени на дорогу (PRD §14). Сбой/отсутствие ключа → оценка без дороги.
#   nominatim — OpenStreetMap, бесплатно, без ключа (dev/старт). Лимит ~1 запрос/с, нужен User-Agent.
#   dadata    — лучшее качество по РФ-адресам, нужен ключ + секрет (рекомендуется на проде).
#   none      — геокодирование выключено (оценка всегда без дороги).
GEOCODER_PROVIDER=nominatim
GEOCODER_USER_AGENT="vanmark-drive/1.0 (dispatch service)"
# Для dadata — ключ и секрет из личного кабинета dadata.ru (оставить пустыми при nominatim/none):
DADATA_API_KEY=
DADATA_SECRET=
